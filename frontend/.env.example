# Copy this file to .env (and .env.local for auth) and fill in real values.
# Never commit the filled-in files.

# --- Database (Supabase Postgres) ---
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL = "Transaction" pooler (port 6543) used by the app at runtime.
# DIRECT_URL   = "Direct connection" (port 5432) used by Prisma migrations.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth (NextAuth) — keep in .env.local ---
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Backend detection service ---
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8000/ws/detect

# --- LINE Official Account (Messaging API) ---
# LINE Developers Console → your Messaging API channel → "Channel access token".
LINE_CHANNEL_ACCESS_TOKEN=
# Optional: user/group/room id to push to. If left blank, dispatch alerts are
# broadcast to all followers of the OA instead.
LINE_TARGET_ID=
